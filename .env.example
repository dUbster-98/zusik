# zusik 설정 예시 — 복사해서 `.env`로 만들고 본인 값으로 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 로 제외되며 절대 커밋되지 않습니다.

# ─── 브로커(증권사) 선택 ───
# BROKER 가 '활성' 증권사 1개를 고릅니다. 아래 여러 브로커 키를 .env 에 함께 넣어둬도 되고,
# 쓸 때 BROKER 값만 바꾸면 즉시 전환됩니다(키 다시 입력 불필요). 검증된 기본은 kis 입니다.
# 브로커별 키가 비어 있으면 KIS_* 로 폴백하므로, 한 곳만 쓰면 KIS_* 만 채워도 됩니다.
# (진짜 여러 곳을 동시 운용하려면 BROKER 가 다른 봇 인스턴스를 따로 실행하세요.)
BROKER=kis                          # kis | toss (활성 1개)
# TOSS_LIVE_ORDERS=true             # 토스 실제 주문 켜기 (미설정 시 주문 dry-run — 검증 후에만)

# ─── 한국투자증권 (KIS) — BROKER=kis ───
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=YOUR_KIS_APP_KEY
KIS_APP_SECRET=YOUR_KIS_APP_SECRET
KIS_ACCOUNT_NO=00000000          # 계좌번호 앞 8자리
KIS_ACCOUNT_PROD=01              # 상품코드 (보통 01) — 모든 브로커 공통
KIS_VIRTUAL=true                 # true=모의투자, false=실거래 (KIS 전용). 모의로 충분히 검증한 뒤에만 false로
                                 # 모의투자는 KIS가 초당 1건만 허용 — 봇이 자동으로 맞춰 호출하므로 사이클이 느린 게 정상
KIS_API_MATURE=false             # 계좌 개설 3일 경과 시 true (rate limit 2.5→18 req/s)

# ─── 토스증권 — BROKER=toss (지원, 라이브 검증) ───
# https://developers.tossinvest.com/docs 에서 API Key / Secret Key 발급(이 둘만 필요).
# 계좌(accountSeq)는 API 로 자동 탐색되어 계좌번호 입력이 필요 없습니다.
# 키 변수명은 TOSS_CLIENT_API_KEY / TOSS_CLIENT_ID / TOSS_API_KEY 중 아무거나 인식됩니다.
# 토스는 모의 샌드박스가 없어 주문 기본 dry-run — 위 TOSS_LIVE_ORDERS=true 로만 실주문.
# TOSS_CLIENT_API_KEY=
# TOSS_CLIENT_SECRET=
# TOSS_ACCOUNT_NO=                 # (선택) 계좌가 여러 개일 때만 특정 계좌 지정

# ─── AI 분석 ───
# CLI(claude/codex/agy)가 설치돼 있으면 자동 감지·우선 사용.
# CLI가 없을 때만 아래 API 키로 폴백.
ANTHROPIC_API_KEY=                # (선택) CLI 없을 때만 필요

# ─── 메신저 알림/명령 (선택) — 설정한 백엔드로 동시 발송 ───
# Discord — 봇 셋업: README의 "Discord Bot Setup" 참고
DISCORD_BOT_TOKEN=                # 슬래시 명령용 봇 토큰 (in-process: 봇이 죽으면 알림 못 보냄)
DISCORD_OWNER_ID=                 # 명령 허용할 본인 Discord user id
DISCORD_WEBHOOK_URL=              # 권장(사실상 필수) — 봇이 죽었을 때 '다운 알림'은 이 웹훅으로만 옴
                                 #   (워치독/OnFailure가 직접 발송. Telegram 설정 시 그쪽으로도 발송)
DISCORD_CHANNEL_ID=              # (선택) 알림 보낼 채널 id. 비우면 첫 채널 자동. 채널 우클릭→ID 복사(개발자모드)
                                 #        또는 원하는 채널에서 /알림채널 명령으로 런타임 지정
# Telegram — @BotFather 로 봇 생성 → 토큰. chat id 는 봇에게 메시지 후 getUpdates 로 확인.
TELEGRAM_BOT_TOKEN=               # 알림 + 명령(폴링) 양방향
TELEGRAM_CHAT_ID=                 # 알림 받을 chat id
# Slack — Incoming Webhook URL (알림). 명령 수신은 Socket Mode app-level token 추가.
SLACK_WEBHOOK_URL=
SLACK_APP_TOKEN=                  # (선택) xapp-... Socket Mode 명령 수신 (없으면 알림 전용)

# ─── 암호화폐 (Upbit, 선택) ───
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

